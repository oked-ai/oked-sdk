{
  "name": "oked-sdk-monorepo",
  "private": true,
  "version": "0.0.0",
  "description": "OKed SDK monorepo — @oked/sdk and @oked/claude-code",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "dev": "npm run dev --workspace @oked/sdk",
    "publish:all": "npm publish --workspaces --access public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/aml11/oked-sdk.git"
  },
  "license": "MIT"
}
